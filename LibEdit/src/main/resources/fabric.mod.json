{
  "schemaVersion": 1,
  "id": "angels-core-lib",
  "version": "${version}",
  "name": "AngelS Core Lib",
  "description": "Core library for AngelSensual mods",
  "authors": [
    "AngelSensual"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
